# =============================================================================
# Environment configuration for the AI Powered Financial Dashboard
# Copy this file to ".env" and adjust the values you want to override.
# =============================================================================

# Port exposed on the host (the container always listens on 8050 internally)
DASHBOARD_PORT=8050

# Ollama model used for AI insights.
# Recommended options (download size in parentheses):
#   - llama3.2:3b   (~2 GB)  light, fast, works on modest hardware (default)
#   - llama3.1:8b   (~4.7 GB) better quality, recommended if you have ≥ 8 GB RAM
#   - mistral:7b    (~4.1 GB) strong reasoning, decent Portuguese support
#   - phi3:mini     (~2.3 GB) very fast, English-leaning
OLLAMA_MODEL=llama3.2:3b

# Timezone used for the "Last update" timestamp on the AI insight panel
TZ=America/Sao_Paulo
